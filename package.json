{
  "name": "xokf",
  "displayName": "xokf",
  "description": "Navigate cross-bundle OKF references via the xokf:// scheme in Markdown.",
  "version": "0.2.1",
  "publisher": "cloorc",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LeafAI/xOKF.git"
  },
  "bugs": {
    "url": "https://github.com/LeafAI/xOKF/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "okf",
    "xokf",
    "knowledge",
    "markdown",
    "links"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:json",
    "onLanguage:jsonc"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "configuration": {
      "title": "xokf",
      "properties": {
        "xokf.federationAnchor": {
          "type": "string",
          "default": "xokf.md",
          "description": "Sentinel filename that marks the federation root. Resolution walks up parent directories to the nearest folder containing this file."
        }
      }
    },
    "commands": [
      {
        "command": "xokf.openPreview",
        "title": "xokf: Open Preview for Linked File"
      },
      {
        "command": "xokf.openInEditor",
        "title": "xokf: Open Linked File in Editor"
      },
      {
        "command": "xokf.exportToPdf",
        "title": "xokf: 导出为 PDF（Export to PDF）",
        "icon": "$(export)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "xokf.openPreview",
          "when": "false"
        },
        {
          "command": "xokf.openInEditor",
          "when": "false"
        },
        {
          "command": "xokf.exportToPdf",
          "when": "editorLangId == markdown"
        }
      ],
      "editor/title": [
        {
          "command": "xokf.exportToPdf",
          "when": "editorLangId == markdown",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint .",
    "pretest": "tsc -p ./tsconfig.test.json",
    "test": "node --test $(find out-tests/test -name '*.test.js')",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "markdown-it": "^14.3.0"
  }
}
